# ── Required ─────────────────────────────────────────────────────────────────

# A strong random string — protect your admin API
ADMIN_API_KEY=change-me-before-deploy

# The URL printed QR codes fall back to if anything goes wrong
FALLBACK_URL=https://forms.gle/mER9B21dKyLRjA9v5

# ── Optional ─────────────────────────────────────────────────────────────────

# Override the database location.
# Default: SQLite file in the project root.
# For PostgreSQL: postgresql+psycopg2://user:password@host:5432/dbname
# DATABASE_URL=sqlite:////data/qr_redirects.db

# Directory where rotating log files are written.
# On Render use /tmp/logs (ephemeral) or mount a disk at /data.
# LOG_DIR=logs

# CRITICAL for Render free tier — SQLite is wiped on every redeploy.
# Paste your slugs here as a JSON array. They are re-seeded on every startup.
# Example:
# SEED_LINKS=[{"slug":"test1","destination_url":"https://forms.gle/..."},{"slug":"table_2","destination_url":"https://forms.gle/..."}]
# SEED_LINKS=
