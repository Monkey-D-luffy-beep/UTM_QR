# QR redirect service — .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment secrets — NEVER commit this
.env

# SQLite database files (keep in deployment env, not git)
*.db
*.db-shm
*.db-wal

# Generated QR code PNGs
qr_codes/

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
